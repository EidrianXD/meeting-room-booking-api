// Schema do Prisma para o sistema de agendamento de salas.
// Datasource: PostgreSQL (Fase 6 — graduação de SQLite -> Postgres).

generator client {
  provider      = "prisma-client-js"
  // "native" mantém o engine do host de desenvolvimento (Windows/macOS/Linux).
  // "debian-openssl-3.0.x" é o target da imagem node:20-slim usada no runtime.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id       String    @id
  name     String
  bookings Booking[]
}

model User {
  id       String    @id @default(uuid())
  username String    @unique
  password String
  bookings Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  title     String
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([roomId, startTime, endTime])
  @@index([userId])
}
