# URL de conexão com o Postgres. No docker-compose, é sobrescrito
# automaticamente para apontar para o serviço `postgres` da network.
# Em dev local sem container, ajuste para um Postgres seu.
DATABASE_URL="postgresql://distrimed:distrimed@localhost:5432/distrimed"

# Segredo usado para assinar e verificar tokens JWT
JWT_SECRET="troque-este-segredo-em-producao"

# Porta do servidor HTTP
PORT=3000

# Origens permitidas para CORS, separadas por vírgula.
# Em dev, deixe vazio: o servidor reflete a Origin de qualquer request.
# Em produção, restrinja para os domínios reais. Exemplo:
# CORS_ORIGINS=https://meusistema.com,https://app.meusistema.com
CORS_ORIGINS=http://localhost:9000,http://seu.ip.exemplo:9000
